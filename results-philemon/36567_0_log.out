  _target_: emg2qwerty.transforms.TemporalAlignmentJitter
  max_offset: 120
standardize:
  _target_: emg2qwerty.transforms.Standardize
  eps: 1.0e-05
  per_channel: true
clip_amplitude:
  _target_: emg2qwerty.transforms.ClipAmplitude
  min_value: -5.0
  max_value: 5.0
add_gaussian_noise:
  _target_: emg2qwerty.transforms.AddGaussianNoise
  std: 0.01
  p: 1.0
logspec:
  _target_: emg2qwerty.transforms.LogSpectrogram
  n_fft: 64
  hop_length: 16
specaug:
  _target_: emg2qwerty.transforms.SpecAugment
  n_time_masks: 3
  time_mask_param: 25
  n_freq_masks: 2
  freq_mask_param: 4
transforms:
  train:
  - ${to_tensor}
  - ${band_rotation}
  - ${temporal_jitter}
  - ${logspec}
  - ${specaug}
